# Optional local overrides — copy to .npmrc only if you need to customize registry auth.
# Local shared development uses `pnpm install:local` (symlinks ../lcs-shared).
# CI and published installs use `pnpm install:ci` / `pnpm install:published`.
#
# Example: add your GitHub Packages token for fetching published @learncraft-spanish/shared
# //npm.pkg.github.com/:_authToken=${GH_PACKAGE_KEY}
# @learncraft-spanish:registry=https://npm.pkg.github.com
package-manager=pnpm
engine-strict=true
